# Build output (rendered artifacts) — anywhere in the tree, since each tool
# has its own build/ or dist/ under its own folder.
build/
dist/

# Raw Google Drive exports staged for conversion (the converted markdown under
# a campaign's assets/ IS committed; the raw gdoc/PDF dump is not).
dnd/*/assets/_raw/

# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.eggs/

# Editor / OS cruft
.vscode/
.idea/
*.swp
.DS_Store

# Secrets (REPLICATE_API_TOKEN etc.)
.env
