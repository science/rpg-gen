{# ===== Reusable layout macros for the secondary sheets ===== #}

{%- macro deco_bar() -%}
<div class="deco-bar"><span class="l"></span><span class="d"></span><span class="d small"></span><span class="d"></span><span class="l"></span></div>
{%- endmacro -%}

{# Section wrapper. Use:  {% call m.section('TITLE', kicker='...') %} ...body... {% endcall %} #}
{%- macro section(title, kicker='') -%}
<section class="sheet-section">
  <header class="sec-head">
    <span class="rule"></span>
    <span class="gem"></span>
    <h2>{{ title }}</h2>
    <span class="gem"></span>
    <span class="rule"></span>
  </header>
  {% if kicker %}<p class="sec-kicker">{{ kicker }}</p>{% endif %}
  <div class="sec-body">
{{ caller() }}
  </div>
</section>
{%- endmacro -%}

{# A labelled fill-in field. Blank fields carry a `.blank` flag and an inner
   `.fill-rule` element: in the identity grid that inner block draws the single
   rule (the per-line gradient is dropped for blanks, which otherwise picks up a
   faint top-edge seam / cell-stretch ghost). Elsewhere the inner element is inert
   and the cell's own border-bottom shows. #}
{%- macro field(label, value='', wide=false) -%}
{%- set _v = '' if value is none else value | string -%}
<div class="field{% if wide %} wide{% endif %}"><span class="field-label">{{ label }}</span><span class="field-value{% if _v | trim == '' %} blank{% endif %}">{% if _v | trim == '' %}<span class="fill-rule"></span>{% else %}{{ _v }}{% endif %}</span></div>
{%- endmacro -%}

{# N blank ruled lines for player fill-in / growth over time. #}
{%- macro lines(n=4, cls='') -%}
<div class="ruled {{ cls }}">{% for _ in range(n) %}<div class="rule-line"></div>{% endfor %}</div>
{%- endmacro -%}

{# A single prose paragraph (skipped if empty). #}
{%- macro prose(text) -%}
{% if text %}<p>{{ text }}</p>{% endif %}
{%- endmacro -%}

{# List of {name, desc, [sub]} entries (people, places, possessions...). #}
{%- macro entries(items, name_key, desc_key, sub_key=none) -%}
{% for it in items or [] %}<div class="entry"><span class="ent-name">{{ it[name_key] }}</span>{% if sub_key and it[sub_key] %} <span class="ent-rel">— {{ it[sub_key] }}</span>{% endif %}<div class="ent-desc">{{ it[desc_key] }}</div></div>
{% endfor %}
{%- endmacro -%}
